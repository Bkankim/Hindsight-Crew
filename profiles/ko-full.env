# ko-full — OPT-IN, NOT v1-verified. Korean multilingual, heavier (multi-GB models, 8-16GB RAM).
HC_PROFILE=ko-full
HINDSIGHT_API_EMBEDDINGS_PROVIDER=local
HINDSIGHT_API_EMBEDDINGS_LOCAL_MODEL=BAAI/bge-m3
HINDSIGHT_API_RERANKER_PROVIDER=local
HINDSIGHT_API_RERANKER_LOCAL_MODEL=BAAI/bge-reranker-v2-m3
# Reranker is hot-swappable (cross-encoder, NOT dimension-locked) — switch anytime, no reindex.
# Korean-tuned alt (measure before claiming better): HINDSIGHT_API_RERANKER_LOCAL_MODEL=dragonkue/bge-reranker-v2-m3-ko
HINDSIGHT_API_RERANKER_LOCAL_MAX_CONCURRENT=1   # 568M on CPU; raise to 2 once stable
HC_EMBED_DIM=1024
