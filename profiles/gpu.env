# gpu profile (opt-in, NOT verified here) — embedding/reranker served by external TEI sidecars on CUDA GPUs.
# TEI provider takes a URL (model is chosen by the TEI server's --model-id), NOT a local model name.
# Launch: text-embeddings-inference --model-id BAAI/bge-m3   and   --model-id BAAI/bge-reranker-v2-m3
HINDSIGHT_API_EMBEDDINGS_PROVIDER=tei
HINDSIGHT_API_EMBEDDINGS_TEI_URL=http://tei-embed:80
HINDSIGHT_API_RERANKER_PROVIDER=tei
HINDSIGHT_API_RERANKER_TEI_URL=http://tei-rerank:80
# embed dim must match the served embedding model (bge-m3 = 1024); locked at boot-0.
HC_EMBED_DIM=1024
HINDSIGHT_API_LLM_PROVIDER=none
