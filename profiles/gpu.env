# gpu — OPT-IN, NOT v1-verified. Same models as ko-full via TEI provider; requires CUDA GPU + TEI.
HC_PROFILE=gpu
HINDSIGHT_API_EMBEDDINGS_PROVIDER=tei
HINDSIGHT_API_EMBEDDINGS_MODEL=BAAI/bge-m3
HINDSIGHT_API_RERANKER_PROVIDER=tei
HINDSIGHT_API_RERANKER_MODEL=dragonkue/bge-reranker-v2-m3-ko
HC_EMBED_DIM=1024
