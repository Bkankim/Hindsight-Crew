# cpu-en — v1 FULLY VERIFIED profile (small, CPU-only, no external network at runtime)
HC_PROFILE=cpu-en
HINDSIGHT_API_EMBEDDINGS_PROVIDER=local
HINDSIGHT_API_EMBEDDINGS_MODEL=BAAI/bge-small-en-v1.5
HINDSIGHT_API_RERANKER_PROVIDER=local
HINDSIGHT_API_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# Embedding dim is LOCKED once data is loaded (changing model = reindex). bge-small-en-v1.5 = 384.
HC_EMBED_DIM=384
