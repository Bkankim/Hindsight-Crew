# ── Hindsight-Crew configuration template ──────────────────────────────
# Copy to .env.local (gitignored) and fill. bootstrap auto-seeds secrets
# if .env.local is absent. NEVER commit real keys/tokens.

# Profile: cpu-en (v1 fully-verified) | ko-full (opt-in, unverified) | gpu (opt-in, unverified)
HC_PROFILE=cpu-en

# Pinned images by DIGEST (not tag) — v0.x is fast-moving. Refresh deliberately.
# Resolve real digests in Stage 2 / via: docker buildx imagetools inspect <ref>
HC_HINDSIGHT_IMAGE=ghcr.io/vectorize-io/hindsight@sha256:REPLACE_WITH_DIGEST
HC_POSTGRES_IMAGE=postgres@sha256:REPLACE_WITH_DIGEST

# Upstream Hindsight auth: single shared Bearer key. The GATEWAY holds this;
# MCP clients NEVER receive it. Auto-generated by seed-demo.sh if unset.
HC_HINDSIGHT_API_KEY=REPLACE_OR_AUTOSEED

# Gateway bind (host side). Hindsight 8888 stays on the internal docker net only.
HC_GATEWAY_BIND=127.0.0.1:8888

# Backup retention (days). find -mtime based cleanup.
HC_BACKUP_RETENTION_DAYS=14

# ACL file: token -> {personal bank, team banks, identity}. Auto-seeded demo if absent.
HC_ACL_FILE=secrets/acl.json
